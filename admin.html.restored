<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin тАФ BLEE Quant</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,system-ui,'Segoe UI',sans-serif;
       background:#0a0f1e;color:#fff;min-height:100vh;padding:24px;}
  header{display:flex;align-items:center;justify-content:space-between;
         margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #1f2937;}
  .logo{font-size:18px;font-weight:800;color:#f5a623;}
  .logo span{color:#fff;}
  .logo sub{font-size:11px;color:#6b7280;font-weight:400;margin-left:6px;}

  .quick-links{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;}
  .quick-link{display:flex;align-items:center;gap:10px;background:#111827;
    border:1px solid #1f2937;border-radius:10px;padding:12px 18px;text-decoration:none;
    transition:border-color .2s,background .2s;flex:1;min-width:180px;}
  .quick-link:hover{border-color:#f5a623;background:#1a1f2e;}
  .quick-link-icon{font-size:22px;line-height:1;}
  .quick-link-title{font-size:13px;font-weight:700;color:#f5a623;}
  .quick-link-sub{font-size:11px;color:#6b7280;margin-top:1px;}
  .quick-link-arrow{margin-left:auto;color:#374151;font-size:14px;}

  .stats{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;}
  .stat{background:#111827;border:1px solid #1f2937;border-radius:10px;
        padding:14px 18px;flex:1;min-width:90px;}
  .stat-val{font-size:26px;font-weight:800;color:#f5a623;}
  .stat-lbl{font-size:11px;color:#6b7280;margin-top:2px;}
  .stat.s-free     .stat-val{color:#9ca3af;}
  .stat.s-starter  .stat-val{color:#4ade80;}
  .stat.s-pro      .stat-val{color:#f5a623;}
  .stat.s-marketer .stat-val{color:#a78bfa;}
  .stat.s-manager  .stat-val{color:#38bdf8;}
  .stat.s-mrr      .stat-val{font-size:20px;color:#60a5fa;}

  .toolbar{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;align-items:center;}
  input.search{background:#111827;border:1px solid #1f2937;color:#fff;
               padding:8px 12px;border-radius:8px;font-size:13px;width:220px;}
  input.search::placeholder{color:#4b5563;}
  input.search:focus{outline:none;border-color:#f5a623;}
  select.filter{background:#111827;border:1px solid #1f2937;color:#fff;
                padding:8px 12px;border-radius:8px;font-size:13px;}
  .btn{padding:8px 14px;border:0;border-radius:8px;font-size:13px;
       font-weight:600;cursor:pointer;transition:opacity .2s;}
  .btn-gold{background:#f5a623;color:#000;}
  .btn-outline{background:transparent;border:1px solid #374151;color:#d1d5db;}
  .btn-danger{background:#7f1d1d;color:#fca5a5;}
  .btn-sm{padding:4px 10px;font-size:12px;}
  .btn:hover{opacity:.8;}

  .card{background:#111827;border:1px solid #1f2937;border-radius:12px;overflow:hidden;}
  table{width:100%;border-collapse:collapse;font-size:13px;}
  th{background:#0d1525;padding:10px 14px;text-align:left;font-size:11px;
     color:#6b7280;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap;}
  td{padding:11px 14px;border-bottom:1px solid #1a2035;vertical-align:middle;}
  tr:last-child td{border-bottom:0;}
  tr:hover td{background:#0f1928;}

  .role-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;
              border-radius:12px;font-size:11px;font-weight:700;}
  .role-admin   {background:#3b1f06;color:#f5a623;border:1px solid #78350f;}
  .role-manager {background:#0c1f2e;color:#38bdf8;border:1px solid #0e4f6e;}
  .role-pro     {background:#1a1f06;color:#facc15;border:1px solid #3f3f00;}
  .role-starter {background:#052e16;color:#4ade80;border:1px solid #14532d;}
  .role-free    {background:#1f2937;color:#9ca3af;border:1px solid #374151;}
  .role-marketer{background:#1a0a2e;color:#a78bfa;border:1px solid #4c1d95;}
  .role-none    {background:#111827;color:#4b5563;border:1px solid #1f2937;}

  .status-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;}
  .status-active   {background:#052e16;color:#4ade80;}
  .status-pending  {background:#1c1a06;color:#ca8a04;}
  .status-inactive {background:#1f1f1f;color:#6b7280;}
  .status-cancelled{background:#2b0a0a;color:#f87171;}

  .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);
            align-items:center;justify-content:center;z-index:100;}
  .modal-bg.show{display:flex;}
  .modal{background:#111827;border:1px solid #1f2937;border-radius:14px;
         padding:28px;max-width:500px;width:90%;max-height:90vh;overflow-y:auto;}
  .modal h3{font-size:16px;font-weight:700;margin-bottom:16px;}
  label.f{display:block;font-size:11px;color:#9ca3af;font-weight:600;
          text-transform:uppercase;margin-bottom:4px;margin-top:14px;}
  input.field,select.field,textarea.field{width:100%;padding:9px 12px;
    background:#1f2937;border:1px solid #374151;border-radius:8px;
    color:#fff;font-size:13px;font-family:inherit;}
  input.field:focus,select.field:focus,textarea.field:focus{outline:none;border-color:#f5a623;}
  textarea.field{resize:vertical;min-height:60px;}
  .hint-box{background:#1f2937;border-radius:8px;padding:10px 12px;
            font-size:13px;color:#9ca3af;margin-top:4px;}
  .modal-btns{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;}
  .info-row{display:flex;gap:6px;font-size:12px;color:#6b7280;margin-top:6px;flex-wrap:wrap;}
  .info-label{color:#4b5563;}
  .promo-field{display:none;}

  .toast{position:fixed;bottom:24px;right:24px;background:#052e16;color:#4ade80;
         border:1px solid #14532d;border-radius:8px;padding:10px 16px;
         font-size:13px;display:none;z-index:200;}
  .empty{padding:32px;text-align:center;color:#4b5563;font-size:14px;}
  .actions{display:flex;gap:6px;flex-wrap:wrap;}

  /* Manager notice banner */
  .manager-notice{background:#0c1f2e;border:1px solid #0e4f6e;border-radius:8px;
                  padding:10px 16px;margin-bottom:16px;font-size:12px;color:#7dd3fc;display:none;}
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">BLEE <span>Quant</span>
      <sub id="header-role-label">Admin Dashboard</sub>
    </div>
  </div>
  <div style="display:flex;gap:10px;align-items:center;">
    <span id="admin-email" style="font-size:12px;color:#6b7280;"></span>
    <button class="btn btn-outline btn-sm" onclick="doSignOut()">Sign out</button>
  </div>
</header>

<!-- Manager notice -->
<div class="manager-notice" id="manager-notice">
  ЁЯЫбя╕П You are logged in as <strong>Manager</strong>. Admin accounts are not shown.
  You can manage Newsletter, Starter, Pro, and Marketer users.
</div>

<!-- My Referral Code (admin/manager can set their own promo code) -->
<div id="my-promo-section" style="display:none;background:#120820;border:1px solid #4c1d95;
     border-radius:10px;padding:14px 18px;margin-bottom:20px;
     display:none;align-items:center;gap:14px;flex-wrap:wrap;">
  <div>
    <div style="font-size:10px;color:#a78bfa;font-weight:700;text-transform:uppercase;
                letter-spacing:.1em;margin-bottom:4px;">My Referral Code</div>
    <div style="font-size:18px;font-weight:800;color:#fff;letter-spacing:.1em;"
         id="my-promo-display">тАФ not set тАФ</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
    <input id="my-promo-input" type="text" placeholder="e.g. BLEE-ADMIN-01"
           maxlength="30"
           style="background:#1f2937;border:1px solid #4c1d95;color:#fff;
                  padding:7px 12px;border-radius:7px;font-size:13px;width:180px;
                  text-transform:uppercase;font-family:inherit;"
           oninput="this.value=this.value.toUpperCase()"/>
    <button onclick="saveMyPromoCode()"
            style="background:#4c1d95;color:#e9d5ff;border:0;border-radius:7px;
                   padding:7px 14px;font-size:12px;font-weight:700;cursor:pointer;">
      Save Code
    </button>
    <button onclick="copyMyPromoLink()" id="copy-my-promo"
            style="background:transparent;border:1px solid #4c1d95;color:#a78bfa;
                   border-radius:7px;padding:7px 14px;font-size:12px;
                   font-weight:700;cursor:pointer;display:none;">
      ЁЯУЛ Copy Link
    </button>
  </div>
  <div style="font-size:11px;color:#6b7280;flex:1;min-width:200px;">
    Set a code and share the referral link to track members you recruit personally.
    Recruits appear in the <a href="marketing.html" style="color:#a78bfa;">Marketing Dashboard</a>.
  </div>
</div>

<!-- Quick Links -->
<div class="quick-links">
  <a href="index.html" class="quick-link">
    <span class="quick-link-icon">ЁЯПа</span>
    <div><div class="quick-link-title">Home</div>
         <div class="quick-link-sub">BLEE Quant homepage</div></div>
    <span class="quick-link-arrow">тА║</span>
  </a>
  <a href="data_flow_diagram.html" class="quick-link">
    <span class="quick-link-icon">ЁЯУК</span>
    <div><div class="quick-link-title">System Data Flow</div>
         <div class="quick-link-sub">Architecture diagram</div></div>
    <span class="quick-link-arrow">тА║</span>
  </a>
  <a href="index2.html" class="quick-link">
    <span class="quick-link-icon">ЁЯУИ</span>
    <div><div class="quick-link-title">Daily Signal</div>
         <div class="quick-link-sub">Today's allocation</div></div>
    <span class="quick-link-arrow">тА║</span>
  </a>
  <a href="Algorithm185History.html" class="quick-link">
    <span class="quick-link-icon">ЁЯУЙ</span>
    <div><div class="quick-link-title">Backtest History</div>
         <div class="quick-link-sub">3-year performance</div></div>
    <span class="quick-link-arrow">тА║</span>
  </a>
  <a href="marketing.html" class="quick-link">
    <span class="quick-link-icon">ЁЯОп</span>
    <div><div class="quick-link-title">Marketing</div>
         <div class="quick-link-sub">Referral & commission</div></div>
    <span class="quick-link-arrow">тА║</span>
  </a>
</div>

<!-- Stats -->
<div class="stats">
  <div class="stat">
    <div class="stat-val" id="stat-total">тАФ</div>
    <div class="stat-lbl">Total Users</div>
  </div>
  <div class="stat s-free">
    <div class="stat-val" id="stat-free">тАФ</div>
    <div class="stat-lbl">ЁЯУз Newsletter</div>
  </div>
  <div class="stat s-starter">
    <div class="stat-val" id="stat-starter">тАФ</div>
    <div class="stat-lbl">тнР Starter</div>
  </div>
  <div class="stat s-pro">
    <div class="stat-val" id="stat-pro">тАФ</div>
    <div class="stat-lbl">ЁЯЪА Pro</div>
  </div>
  <div class="stat s-marketer">
    <div class="stat-val" id="stat-marketer">тАФ</div>
    <div class="stat-lbl">ЁЯОп Marketers</div>
  </div>
  <!-- Admin-only stats -->
  <div class="stat s-manager" id="stat-manager-card" style="display:none;">
    <div class="stat-val" id="stat-manager">тАФ</div>
    <div class="stat-lbl">ЁЯЫбя╕П Managers</div>
  </div>
  <div class="stat s-mrr">
    <div class="stat-val" id="stat-mrr">тАФ</div>
    <div class="stat-lbl">Est. MRR</div>
  </div>
</div>

<!-- Toolbar -->
<div class="toolbar">
  <input class="search" id="search" type="text"
         placeholder="Search emailтАж" oninput="renderTable()"/>
  <select class="filter" id="filter-role" onchange="renderTable()">
    <option value="">All roles</option>
    <option value="free">ЁЯУз Newsletter</option>
    <option value="basic">тнР Starter</option>
    <option value="premium">ЁЯЪА Pro</option>
    <option value="marketer">ЁЯОп Marketer</option>
    <!-- admin-only options added by JS -->
  </select>
  <select class="filter" id="filter-status" onchange="renderTable()">
    <option value="">All statuses</option>
    <option value="active">Active</option>
    <option value="pending">Pending</option>
    <option value="inactive">Inactive</option>
    <option value="cancelled">Cancelled</option>
  </select>
  <button class="btn btn-gold" onclick="openAddModal()">+ Add User</button>
  <button class="btn btn-outline" onclick="loadUsers()" style="margin-left:auto;">тЯ│ Refresh</button>
</div>

<!-- User Table -->
<div class="card">
  <table>
    <thead>
      <tr>
        <th>Email</th>
        <th>Role</th>
        <th>Status</th>
        <th>Plan / Code</th>
        <th>Started</th>
        <th>Last Login</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="user-tbody">
      <tr><td colspan="7" class="empty">LoadingтАж</td></tr>
    </tbody>
  </table>
</div>

<!-- тФАтФА EDIT USER MODAL тФАтФА -->
<div class="modal-bg" id="edit-modal">
  <div class="modal">
    <h3 id="modal-title">Edit User</h3>
    <input type="hidden" id="edit-uid"/>

    <label class="f">Email</label>
    <input class="field" id="edit-email" type="email" readonly
           style="opacity:.6;cursor:default;"/>

    <label class="f">Role / Tier</label>
    <select class="field" id="edit-tier" onchange="togglePromoField('edit')">
      <option value="none">тАФ None (no access)</option>
      <option value="free">ЁЯУз Newsletter (backtest + market forecast)</option>
      <option value="basic">тнР Starter ($19/mo)</option>
      <option value="premium">ЁЯЪА Pro ($49/mo) тАФ all features + auto-trade</option>
      <option value="marketer">ЁЯОп Marketer (referral partner)</option>
      <!-- admin-only options injected by JS -->
    </select>

    <div class="promo-field" id="edit-promo-row">
      <label class="f">Promo Code</label>
      <input class="field" id="edit-promoCode" type="text"
             placeholder="e.g. BLEE-JOHN-01" style="text-transform:uppercase;"
             oninput="this.value=this.value.toUpperCase()"/>
    </div>

    <label class="f">Subscription Status</label>
    <select class="field" id="edit-status">
      <option value="active">тЬЕ Active</option>
      <option value="pending">тП│ Pending</option>
      <option value="inactive">тЭМ Inactive</option>
      <option value="cancelled">ЁЯЪл Cancelled</option>
    </select>

    <label class="f">Security Hint</label>
    <div class="hint-box" id="edit-hint">тАФ</div>

    <label class="f">Admin Notes</label>
    <textarea class="field" id="edit-notes" rows="2"
              placeholder="Internal notesтАж"></textarea>

    <div class="info-row" id="edit-info"></div>

    <div class="modal-btns">
      <button class="btn btn-danger btn-sm" id="btn-delete"
              onclick="deleteUser()">Delete</button>
      <button class="btn btn-outline" onclick="sendResetFromModal()">
        ЁЯУз Send Reset
      </button>
      <button class="btn btn-outline" onclick="closeEditModal()">Cancel</button>
      <button class="btn btn-gold" onclick="saveUser()">Save & Sync</button>
    </div>
  </div>
</div>

<!-- тФАтФА ADD USER MODAL тФАтФА -->
<div class="modal-bg" id="add-modal">
  <div class="modal">
    <h3>Add / Invite User</h3>
    <p style="font-size:12px;color:#6b7280;margin-bottom:16px;line-height:1.6;">
      Creates a Firestore record so the user's role is pre-set when they register.
      For Marketers, the promo code activates on first login.
    </p>

    <label class="f">Email Address</label>
    <input class="field" id="add-email" type="email"
           placeholder="member@example.com"/>

    <label class="f">Role / Tier</label>
    <select class="field" id="add-tier" onchange="togglePromoField('add')">
      <option value="free">ЁЯУз Newsletter (backtest + market forecast)</option>
      <option value="basic">тнР Starter ($19/mo)</option>
      <option value="premium">ЁЯЪА Pro ($49/mo) тАФ all features + auto-trade</option>
      <option value="marketer">ЁЯОп Marketer (referral partner)</option>
      <!-- admin-only options injected by JS -->
    </select>

    <div class="promo-field" id="add-promo-row">
      <label class="f">Promo Code
        <span style="color:#6b7280;font-weight:400;">
          (unique тАФ marketer shares this to recruit members)
        </span>
      </label>
      <input class="field" id="add-promoCode" type="text"
             placeholder="e.g. BLEE-JOHN-01" style="text-transform:uppercase;"
             oninput="this.value=this.value.toUpperCase()"/>
    </div>

    <label class="f">Subscription Status</label>
    <select class="field" id="add-status">
      <option value="active">тЬЕ Active (grant access now)</option>
      <option value="pending">тП│ Pending (awaiting payment)</option>
    </select>

    <label class="f">Security Hint (optional)</label>
    <input class="field" id="add-hint" type="text"
           placeholder="Optional hint for the user"/>

    <label class="f">Admin Notes</label>
    <input class="field" id="add-notes" type="text"
           placeholder="e.g. 'Beta tester', 'Partner from conference'"/>

    <div class="modal-btns">
      <button class="btn btn-outline" onclick="closeAddModal()">Cancel</button>
      <button class="btn btn-gold" onclick="addUser()">Add & Sync to Firestore</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
<script src="firebase-config.js"></script>
<script>
if (!firebase.apps.length) firebase.initializeApp(FIREBASE_CONFIG);
const auth = firebase.auth();
const db   = firebase.firestore();

let allUsers            = [];
let currentRole         = "";    // "admin" | "manager"
let currentFirebaseUser = null;
let myPromoCode         = "";

// тФАт